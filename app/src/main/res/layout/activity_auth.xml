<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="?attr/colorSurface">

    <!-- نوار وضعیت آفلاین -->
    <LinearLayout
        android:id="@+id/offline_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:paddingHorizontal="16dp"
        android:background="#E53935"
        android:visibility="gone">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_cloud_offline"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/offline_message"
            android:textColor="@android:color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- پیام برای کاربر لاگین شده بدون خانواده که آفلاین است -->
    <TextView
        android:id="@+id/tv_offline_family_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="شما وارد حساب شده‌اید اما هنوز خانواده‌ای نساخته‌اید.\nلطفاً برای ساخت یا پیوستن به خانواده، به اینترنت متصل شوید."
        android:textColor="?attr/colorOnSurface"
        android:textSize="14sp"
        android:gravity="center"
        android:background="@color/secondary_container"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/auth_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>

